{
  "expo": {
    "name": "are we",
    "slug": "what-are-we",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "arewe",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#da4840"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.arewe.app",
      "buildNumber": "6",
      "associatedDomains": [
        "applinks:arewe.app",
        "applinks:askarewe.com"
      ],
      "infoPlist": {
        "NSContactsUsageDescription": "We need access to your contacts so you can send the question to someone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#da4840"
      },
      "package": "com.arewe.app",
      "permissions": [
        "READ_CONTACTS",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-contacts",
      "expo-notifications",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": "https://arewe.app"
      },
      "eas": {
        "projectId": "54c4e4d4-ff14-4e22-a528-40b6cddfdf75"
      }
    },
    "owner": "nordygal"
  }
}
